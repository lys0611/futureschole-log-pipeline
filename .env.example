# GCP 프로젝트와 리전
PROJECT_ID=
REGION=asia-northeast3
ZONE=asia-northeast3-a
VPC_NAME=futureschole-vpc
SUBNET_NAME=futureschole-subnet-seoul
VM_NAME=futureschole-pipeline-vm
VM_EXTERNAL_IP=
VM_TAG=api-health

# GCP Managed Service for Apache Kafka
KAFKA_CLUSTER_NAME=kafka-clu
KAFKA_BOOTSTRAP_SERVERS=

# GCP Managed Kafka SASL 인증
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# MySQL Debezium CDC
MYSQL_DEBEZIUM_USER=debezium
MYSQL_DEBEZIUM_PASSWORD=

# GCS S3-compatible Object Storage
BUCKET_NAME=replace-with-gcs-bucket-name
OBJECT_STORAGE_ENDPOINT=https://storage.googleapis.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
S3_TOPICS_DIR=raw

# BigQuery와 Looker Studio 참고 값
BIGQUERY_DATASET=futureschole_logs
LOOKER_STUDIO_SCREENSHOT_PATH=docs/images/dashboard.png
# LOOKER_STUDIO_REPORT_URL=replace-with-actual-looker-studio-report-url
