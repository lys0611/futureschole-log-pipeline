# GCP 프로젝트와 리전
PROJECT_ID=replace-with-gcp-project-id
REGION=replace-with-region
ZONE=replace-with-zone
VPC_NAME=replace-with-vpc-name
SUBNET_NAME=replace-with-subnet-name
VM_NAME=replace-with-vm-name
VM_EXTERNAL_IP=replace-with-vm-external-ip

# GCP Managed Service for Apache Kafka
KAFKA_CLUSTER_NAME=replace-with-managed-kafka-cluster-name
KAFKA_BOOTSTRAP_SERVERS=replace-with-managed-kafka-bootstrap-host:9092
LOGSTASH_KAFKA_ENDPOINT=replace-with-managed-kafka-bootstrap-host:9092

# GCP Managed Kafka SASL 인증
KAFKA_SECURITY_PROTOCOL=SASL_SSL
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=replace-with-kafka-client-service-account-email
KAFKA_SASL_PASSWORD=replace-with-kafka-sasl-password

# MySQL Debezium CDC
MYSQL_DEBEZIUM_USER=debezium
MYSQL_DEBEZIUM_PASSWORD=replace-with-local-debezium-password

# GCS S3-compatible Object Storage
BUCKET_NAME=replace-with-gcs-bucket-name
OBJECT_STORAGE_ENDPOINT=https://storage.googleapis.com
OBJECT_STORAGE_REGION=auto
OBJECT_STORAGE_ACCESS_KEY=replace-with-gcs-hmac-access-id
OBJECT_STORAGE_SECRET_KEY=replace-with-gcs-hmac-secret
S3_TOPICS_DIR=raw

# BigQuery와 Looker Studio 참고 값
BIGQUERY_DATASET=replace-with-bigquery-dataset
LOOKER_STUDIO_REPORT_URL=replace-with-report-url-or-docs/images/dashboard.png
