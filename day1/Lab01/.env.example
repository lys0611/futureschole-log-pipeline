# External Kafka bootstrap servers. Create the Kafka service manually in your cloud
# provider and paste its bootstrap address list here. Do not use kafka:9092.
KAFKA_BOOTSTRAP_SERVERS=broker1.example.com:9092,broker2.example.com:9092

# Logstash sends Nginx access logs to this Kafka endpoint.
# For plaintext Kafka this can match KAFKA_BOOTSTRAP_SERVERS.
LOGSTASH_KAFKA_ENDPOINT=broker1.example.com:9092,broker2.example.com:9092
